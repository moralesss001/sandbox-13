BINANCE_PUBLIC_BASE_URL=https://fapi.binance.com
BINANCE_TESTNET_BASE_URL=https://demo-fapi.binance.com

API_MODE=paper

# Only for testnet mode, never production.
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=

ALLOW_TESTNET_ORDERS=false
ALLOW_REAL_ORDERS=false

# Telegram read-only control panel.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=
TELEGRAM_READ_ONLY=true
PRODUCTION_TRADING_ENABLED=false
